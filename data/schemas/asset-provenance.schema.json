{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://three-kingdom.local/schemas/asset-provenance.schema.json",
  "title": "AssetProvenanceDocument",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "assets"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schemaVersion", "assetId", "contentIds", "origin", "rightsStatus", "modelServiceVersion", "generationDate", "inputSources", "promptBrief", "humanEdits", "reviewer", "commercialRightsEvidence", "sha256", "humanApproved", "releaseEligible", "classification"],
        "properties": {
          "schemaVersion": { "const": 1 },
          "assetId": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]*:[a-z][a-z0-9_./-]*$" },
          "contentIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
          "origin": { "enum": ["human", "offlineAi", "liveGenerated"] },
          "rightsStatus": { "type": "string", "minLength": 1 },
          "modelServiceVersion": { "type": ["string", "null"] },
          "generationDate": { "type": ["string", "null"] },
          "inputSources": { "type": ["string", "null"] },
          "promptBrief": { "type": ["string", "null"] },
          "humanEdits": { "type": "string" },
          "reviewer": { "type": "string" },
          "commercialRightsEvidence": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "humanApproved": { "type": "boolean" },
          "releaseEligible": { "type": "boolean" },
          "classification": { "enum": ["general", "nonExplicitRelationship", "sexuallyExplicit"] }
        }
      }
    }
  }
}
