{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://three-kingdom.local/schemas/content-manifest.schema.json",
  "title": "ContentManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packId",
    "version",
    "minimumGameVersion",
    "contentSchemaVersion",
    "isBuiltIn",
    "releaseEligible",
    "dependencies",
    "loadPriority",
    "files",
    "authors",
    "provenance",
    "checksum"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "packId": { "$ref": "#/$defs/entityId" },
    "version": { "$ref": "#/$defs/semver" },
    "minimumGameVersion": { "$ref": "#/$defs/semver" },
    "contentSchemaVersion": { "const": 1 },
    "isBuiltIn": { "type": "boolean" },
    "releaseEligible": { "type": "boolean" },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["packId", "versionRequirement", "required"],
        "properties": {
          "packId": { "$ref": "#/$defs/entityId" },
          "versionRequirement": { "type": "string", "minLength": 5 },
          "required": { "type": "boolean" }
        }
      }
    },
    "loadPriority": { "type": "integer", "minimum": -100000, "maximum": 100000 },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "kind", "sha256"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240,
            "pattern": "^[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$"
          },
          "kind": { "enum": ["records", "overrides", "localization", "glossary", "sources", "provenance"] },
          "sha256": { "$ref": "#/$defs/sha256" }
        }
      }
    },
    "authors": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["license", "rightsHolder", "sourceRegister", "assetRegister"],
      "properties": {
        "license": { "type": "string", "minLength": 1 },
        "rightsHolder": { "type": "string", "minLength": 1 },
        "sourceRegister": { "type": "string", "minLength": 1 },
        "assetRegister": { "type": "string", "minLength": 1 }
      }
    },
    "checksum": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "entityId": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]*:[a-z][a-z0-9_./-]*$", "maxLength": 160 },
    "semver": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
