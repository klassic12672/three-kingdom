{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://three-kingdom.local/schemas/content-override.schema.json",
  "title": "ContentOverrideDocument",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "overrides"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schemaVersion", "targetId", "fields"],
        "properties": {
          "schemaVersion": { "const": 1 },
          "targetId": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]*:[a-z][a-z0-9_./-]*$" },
          "fields": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["jsonPath", "value"],
              "properties": {
                "jsonPath": { "type": "string", "pattern": "^/" },
                "value": true
              }
            }
          }
        }
      }
    }
  }
}
