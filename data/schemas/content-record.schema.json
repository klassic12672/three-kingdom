{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://three-kingdom.local/schemas/content-record.schema.json",
  "title": "ContentRecordDocument",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "records"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schemaVersion", "id", "recordType", "contentTag", "classification", "sourceIds", "localizationKeys", "releaseMarked", "data"],
        "properties": {
          "schemaVersion": { "const": 1 },
          "id": { "$ref": "#/$defs/entityId" },
          "recordType": { "type": "string", "minLength": 1 },
          "contentTag": { "enum": ["historical", "disputed", "inferred", "romance", "fictional"] },
          "classification": { "enum": ["general", "nonExplicitRelationship", "sexuallyExplicit"] },
          "sourceIds": { "$ref": "#/$defs/entityIdArray" },
          "localizationKeys": { "$ref": "#/$defs/entityIdArray" },
          "releaseMarked": { "type": "boolean" },
          "data": { "type": "object" }
        },
        "allOf": [
          {
            "if": { "properties": { "recordType": { "const": "character_world" } }, "required": ["recordType"] },
            "then": { "properties": { "data": { "$ref": "#/$defs/characterWorldData" } } }
          },
          {
            "if": { "properties": { "recordType": { "const": "character_definition" } }, "required": ["recordType"] },
            "then": { "properties": { "data": { "$ref": "#/$defs/characterDefinitionData" } } }
          },
          {
            "if": { "properties": { "recordType": { "const": "family_definition" } }, "required": ["recordType"] },
            "then": { "properties": { "data": { "$ref": "#/$defs/namedCharacterDefinitionData" } } }
          },
          {
            "if": { "properties": { "recordType": { "const": "household_definition" } }, "required": ["recordType"] },
            "then": { "properties": { "data": { "$ref": "#/$defs/namedCharacterDefinitionData" } } }
          },
          {
            "if": { "properties": { "recordType": { "const": "character_identity_definition" } }, "required": ["recordType"] },
            "then": { "properties": { "data": { "$ref": "#/$defs/characterIdentityDefinitionData" } } }
          }
        ]
      }
    }
  },
  "$defs": {
    "entityId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]*:[a-z][a-z0-9_./-]*$",
      "maxLength": 160
    },
    "nullableEntityId": {
      "oneOf": [
        { "$ref": "#/$defs/entityId" },
        { "type": "null" }
      ]
    },
    "entityIdArray": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/entityId" }
    },
    "campaignDate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["year", "month", "day"],
      "properties": {
        "year": { "type": "integer", "minimum": 1, "maximum": 9999 },
        "month": { "type": "integer", "minimum": 1, "maximum": 12 },
        "day": { "type": "integer", "minimum": 1, "maximum": 31 }
      }
    },
    "legacyCharacterState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "characterId", "parentIds"],
      "properties": {
        "contractVersion": { "const": 1 },
        "characterId": { "$ref": "#/$defs/entityId" },
        "parentIds": { "$ref": "#/$defs/entityIdArray" }
      }
    },
    "characterParentLink": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parentCharacterId", "kind"],
      "properties": {
        "parentCharacterId": { "$ref": "#/$defs/entityId" },
        "kind": { "enum": ["unspecifiedLegacy", "biological", "legalAdoptive"] }
      }
    },
    "characterCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vitalStatus", "healthStatus", "isIncapacitated", "custodyStatus", "custodianId"],
      "properties": {
        "vitalStatus": { "enum": ["alive", "dead"] },
        "healthStatus": { "enum": ["healthy", "injured", "ill", "critical"] },
        "isIncapacitated": { "type": "boolean" },
        "custodyStatus": { "enum": ["free", "detained", "captive", "hostage"] },
        "custodianId": { "$ref": "#/$defs/nullableEntityId" }
      }
    },
    "currentCharacterState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "characterId", "parentIds", "parentLinks", "condition"],
      "properties": {
        "contractVersion": { "const": 2 },
        "characterId": { "$ref": "#/$defs/entityId" },
        "parentIds": { "$ref": "#/$defs/entityIdArray" },
        "parentLinks": { "type": "array", "items": { "$ref": "#/$defs/characterParentLink" } },
        "condition": { "$ref": "#/$defs/characterCondition" }
      }
    },
    "legacyFamilyState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "familyId", "memberIds"],
      "properties": {
        "contractVersion": { "const": 1 },
        "familyId": { "$ref": "#/$defs/entityId" },
        "memberIds": { "$ref": "#/$defs/entityIdArray" }
      }
    },
    "currentFamilyState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "familyId", "memberIds"],
      "properties": {
        "contractVersion": { "const": 2 },
        "familyId": { "$ref": "#/$defs/entityId" },
        "memberIds": { "$ref": "#/$defs/entityIdArray" }
      }
    },
    "legacyHouseholdState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "householdId", "headCharacterId", "memberIds"],
      "properties": {
        "contractVersion": { "const": 1 },
        "householdId": { "$ref": "#/$defs/entityId" },
        "headCharacterId": { "$ref": "#/$defs/entityId" },
        "memberIds": { "$ref": "#/$defs/entityIdArray" }
      }
    },
    "currentHouseholdState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "householdId", "headCharacterId", "memberIds"],
      "properties": {
        "contractVersion": { "const": 2 },
        "householdId": { "$ref": "#/$defs/entityId" },
        "headCharacterId": { "$ref": "#/$defs/entityId" },
        "memberIds": { "$ref": "#/$defs/entityIdArray" }
      }
    },
    "legacyCharacterWorldData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "identityDefinitionIds", "characterDefinitionIds", "familyDefinitionIds", "householdDefinitionIds", "characterStates", "familyStates", "householdStates", "references"],
      "properties": {
        "contractVersion": { "const": 1 },
        "identityDefinitionIds": { "$ref": "#/$defs/entityIdArray" },
        "characterDefinitionIds": { "$ref": "#/$defs/entityIdArray" },
        "familyDefinitionIds": { "$ref": "#/$defs/entityIdArray" },
        "householdDefinitionIds": { "$ref": "#/$defs/entityIdArray" },
        "characterStates": { "type": "array", "items": { "$ref": "#/$defs/legacyCharacterState" } },
        "familyStates": { "type": "array", "items": { "$ref": "#/$defs/legacyFamilyState" } },
        "householdStates": { "type": "array", "items": { "$ref": "#/$defs/legacyHouseholdState" } },
        "references": { "$ref": "#/$defs/entityIdArray" }
      }
    },
    "currentCharacterWorldData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "identityDefinitionIds", "characterDefinitionIds", "familyDefinitionIds", "householdDefinitionIds", "characterStates", "familyStates", "householdStates", "references"],
      "properties": {
        "contractVersion": { "const": 2 },
        "identityDefinitionIds": { "$ref": "#/$defs/entityIdArray" },
        "characterDefinitionIds": { "$ref": "#/$defs/entityIdArray" },
        "familyDefinitionIds": { "$ref": "#/$defs/entityIdArray" },
        "householdDefinitionIds": { "$ref": "#/$defs/entityIdArray" },
        "characterStates": { "type": "array", "items": { "$ref": "#/$defs/currentCharacterState" } },
        "familyStates": { "type": "array", "items": { "$ref": "#/$defs/currentFamilyState" } },
        "householdStates": { "type": "array", "items": { "$ref": "#/$defs/currentHouseholdState" } },
        "references": { "$ref": "#/$defs/entityIdArray" }
      }
    },
    "characterWorldData": {
      "oneOf": [
        { "$ref": "#/$defs/legacyCharacterWorldData" },
        { "$ref": "#/$defs/currentCharacterWorldData" }
      ]
    },
    "legacyCharacterDefinitionData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "nameKey", "birthDate", "abilityIds", "aptitudeIds", "traitIds", "ambitionIds", "reputationIds", "references"],
      "properties": {
        "contractVersion": { "const": 1 },
        "nameKey": { "$ref": "#/$defs/entityId" },
        "birthDate": { "$ref": "#/$defs/campaignDate" },
        "abilityIds": { "$ref": "#/$defs/entityIdArray" },
        "aptitudeIds": { "$ref": "#/$defs/entityIdArray" },
        "traitIds": { "$ref": "#/$defs/entityIdArray" },
        "ambitionIds": { "$ref": "#/$defs/entityIdArray" },
        "reputationIds": { "$ref": "#/$defs/entityIdArray" },
        "references": { "$ref": "#/$defs/entityIdArray" }
      }
    },
    "currentCharacterDefinitionData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "nameKey", "courtesyNameKey", "originKind", "cultureId", "originLocationId", "birthDate", "abilityIds", "aptitudeIds", "traitIds", "ambitionIds", "reputationIds", "flawIds", "references"],
      "properties": {
        "contractVersion": { "const": 2 },
        "nameKey": { "$ref": "#/$defs/entityId" },
        "courtesyNameKey": { "$ref": "#/$defs/nullableEntityId" },
        "originKind": { "enum": ["authored", "custom"] },
        "cultureId": { "$ref": "#/$defs/nullableEntityId" },
        "originLocationId": { "$ref": "#/$defs/nullableEntityId" },
        "birthDate": { "$ref": "#/$defs/campaignDate" },
        "abilityIds": { "$ref": "#/$defs/entityIdArray" },
        "aptitudeIds": { "$ref": "#/$defs/entityIdArray" },
        "traitIds": { "$ref": "#/$defs/entityIdArray" },
        "ambitionIds": { "$ref": "#/$defs/entityIdArray" },
        "reputationIds": { "$ref": "#/$defs/entityIdArray" },
        "flawIds": { "$ref": "#/$defs/entityIdArray" },
        "references": { "$ref": "#/$defs/entityIdArray" }
      }
    },
    "characterDefinitionData": {
      "oneOf": [
        { "$ref": "#/$defs/legacyCharacterDefinitionData" },
        { "$ref": "#/$defs/currentCharacterDefinitionData" }
      ]
    },
    "legacyNamedCharacterDefinitionData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "nameKey", "references"],
      "properties": {
        "contractVersion": { "const": 1 },
        "nameKey": { "$ref": "#/$defs/entityId" },
        "references": { "$ref": "#/$defs/entityIdArray" }
      }
    },
    "currentNamedCharacterDefinitionData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "nameKey", "references"],
      "properties": {
        "contractVersion": { "const": 2 },
        "nameKey": { "$ref": "#/$defs/entityId" },
        "references": { "$ref": "#/$defs/entityIdArray" }
      }
    },
    "namedCharacterDefinitionData": {
      "oneOf": [
        { "$ref": "#/$defs/legacyNamedCharacterDefinitionData" },
        { "$ref": "#/$defs/currentNamedCharacterDefinitionData" }
      ]
    },
    "legacyCharacterIdentityDefinitionData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "kind", "nameKey", "references"],
      "properties": {
        "contractVersion": { "const": 1 },
        "kind": { "enum": ["ability", "aptitude", "trait", "ambition", "reputation"] },
        "nameKey": { "$ref": "#/$defs/entityId" },
        "references": { "$ref": "#/$defs/entityIdArray" }
      }
    },
    "currentCharacterIdentityDefinitionData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "kind", "nameKey", "references"],
      "properties": {
        "contractVersion": { "const": 2 },
        "kind": { "enum": ["ability", "aptitude", "trait", "ambition", "reputation", "flaw"] },
        "nameKey": { "$ref": "#/$defs/entityId" },
        "references": { "$ref": "#/$defs/entityIdArray" }
      }
    },
    "characterIdentityDefinitionData": {
      "oneOf": [
        { "$ref": "#/$defs/legacyCharacterIdentityDefinitionData" },
        { "$ref": "#/$defs/currentCharacterIdentityDefinitionData" }
      ]
    }
  }
}
