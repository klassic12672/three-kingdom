root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,csproj,props,targets}]
indent_style = space
indent_size = 4

[*.{json,jsonc,yml,yaml,md,godot,tscn,cfg}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{sln,slnx}]
indent_style = tab
