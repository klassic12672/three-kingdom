; Engine configuration file.
; Edit through Godot where practical; keep this file reviewable in source control.
config_version=5

[application]

config/name="Three Kingdoms Grand Strategy"
config/description="Route-based Three Kingdoms campaign simulation"
config/version="0.1.0"
config/features=PackedStringArray("4.6", "C#", "GL Compatibility")
run/main_scene="res://scenes/Main.tscn"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="Game.Presentation"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.035, 0.043, 0.055, 1)
textures/vram_compression/import_etc2_astc=true
